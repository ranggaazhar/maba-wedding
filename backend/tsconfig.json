{
  "compilerOptions": {
    // File Layout
    "outDir": "./dist",
    "rootDir": "./",

    // Environment Settings
    "module": "nodenext",
    "target": "esnext",
    "types": ["node"],
    "lib": ["esnext"],

    // Allow JavaScript during migration
    "allowJs": true,
    "checkJs": false,  // Set true kalau mau type-check JS files

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Recommended Options
    "strict": true,
    "esModuleInterop": true,  // Tambahkan ini untuk kompatibilitas CommonJS
    "resolveJsonModule": true,  // Kalau import JSON
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
  },
  "include": [
    "**/*.ts",
    "**/*.js"  // Include JS files untuk transisi
  ],
  "exclude": [
    "node_modules",
    "dist",
    "frontend"
  ]
}